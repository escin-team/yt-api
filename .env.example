# ============================================
# UNIVERSAL ENVIRONMENT VARIABLES
# Compatible: HF Spaces, Back4App, Defang, Railway, Render
# ============================================

# YouTube crawler configuration
YOUTUBE_BASE_URL=https://www.youtube.com/results
YOUTUBE_TIMEOUT=10

# Redis cache configuration (DISABLED untuk HF Spaces)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=3
REDIS_PASSWORD=
REDIS_ENABLED=false
REDIS_TTL_SECONDS=3600

# API server configuration (Port 7860 untuk HF Spaces)
API_HOST=0.0.0.0
API_PORT=7860
API_LOG_LEVEL=info

# Logging configuration
LOG_DIR=logs
LOG_FILE_ENABLED=true
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# MCP Configuration
MCP_SEARCH_TIMEOUT=15
MCP_SEARCH_RETRIES=3

# Feature flags
ENABLE_CACHE=true
ENABLE_LOGGING=true

# Audio download configuration
DOWNLOAD_DIR=/tmp/youtube_audio
DOWNLOAD_BASE_URL=http://localhost:7860/downloads
DOWNLOAD_TIMEOUT=300
MAX_VIDEO_DURATION=600
AUDIO_BITRATE=128
CACHE_TTL_HOURS=24

# Cloudinary (WAJIB diisi via HF Secrets)
CLOUDINARY_ACCOUNTS_JSON=[]

# Rate limiting configuration
RATE_LIMIT_DOWNLOAD_PER_HOUR=20
RATE_LIMIT_STATIC_PER_MINUTE=60
RATE_LIMIT_ENABLED=true